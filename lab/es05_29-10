type ide = string;;
  
type expr =
  | True
  | False
  | Var of string
  | Const of int     
  | Not of expr
  | And of expr * expr
  | Or of expr * expr
  | Add of expr * expr
  | Sub of expr * expr
  | Mul of expr * expr
  | Eq of expr * expr
  | Leq of expr * expr
;;

type cmd =
  | Skip
  | Assign of string * expr
  | Seq of cmd * cmd
  | If of expr * cmd * cmd
  | While of expr * cmd
;;

type exprval = Bool of bool | Nat of int;;        (* value of an expression *)
type state = ide -> exprval;;                     (* state = map from identifiers to expression values *)
type conf = St of state | Cmd of cmd * state;;    (* configuration = state | (command,state) *)


exception UnboundVar of string;;
exception NoRuleApplies;;

let bottom : state = fun x -> raise (UnboundVar x);;

let rec eval_expr st e = match e with
  | True -> Bool true
  | False -> Bool false
  | Var (x) -> st x
  | Const (n) -> Nat n
  | Not (e1) -> (match eval_expr st e1 with
              | Bool b -> Bool (not b)
              | Nat n -> failwith "Type error: Not expects a Bool argument")
  | And (e1, e2) -> (match eval_expr st e1, eval_expr st e2 with
              | Bool b1, Bool b2 -> Bool (b1 && b2)
              | _, _ -> failwith "Type error: And expects Bool arguments")
  | Or (e1, e2) -> (match eval_expr st e1, eval_expr st e2 with
              | Bool b1, Bool b2 -> Bool (b1 || b2)
              | _, _ -> failwith "Type error: Or expects Bool arguments")
  | Add (e1, e2) -> (match eval_expr st e1, eval_expr st e2 with
              | Nat n1, Nat n2 -> Nat (n1 + n2)
              | _, _ -> failwith "Type error: Add expects Nat arguments")
  | Sub (e1, e2) -> (match eval_expr st e1, eval_expr st e2 with
              | Nat n1, Nat n2 -> Nat (n1 - n2)
              | _, _ -> failwith "Type error: Sub expects Nat arguments")
  | Mul (e1, e2) -> (match eval_expr st e1, eval_expr st e2 with
              | Nat n1, Nat n2 -> Nat (n1 * n2)
              | _, _ -> failwith "Type error: Mul expects Nat arguments")
  | Eq (e1, e2) -> (match eval_expr st e1, eval_expr st e2 with
              | Nat n1, Nat n2 -> Bool (n1 = n2)
              | _, _ -> failwith "Type error: Eq expects Nat arguments")
  | Leq (e1, e2) -> (match eval_expr st e1, eval_expr st e2 with
              | Nat n1, Nat n2 -> Bool (n1 <= n2)
              | _, _ -> failwith "Type error: Leq expects Nat arguments")
;;

let bind st x v =
  fun y -> if y = x then v else st y
;;

let rec trace1 c = match c with
  | St _ -> raise NoRuleApplies
  | Cmd (Skip, st) -> St st
  | Cmd (Assign (x, e), st) -> let v = eval_expr st e in
                                St (bind st x v)
  | Cmd (Seq (c1, c2), st) -> (match trace1 (Cmd (c1, st)) with
                                | St st1 -> Cmd (c2, st1)
                                | Cmd (c1', st1) -> Cmd (Seq (c1', c2), st1))
  | Cmd (If (e, c1, c2), st) -> (match eval_expr st e with
                                  | Bool true -> Cmd (c1, st)
                                  | Bool false -> Cmd (c2, st)
                                  | Nat n -> failwith "Type error: If expects a Bool condition")
  | Cmd (While (e, c), st) -> (match eval_expr st e with
                                  | Bool true -> Cmd (Seq (c, While (e, c)), st)
                                  | Bool false -> St st
                                  | Nat n -> failwith "Type error: While expects a Bool condition")
;;

let rec trace n c =
  let rec aux n conf =
    if n <= 0 then [conf]
    else
      try
        let conf' = trace1 conf in
        conf :: aux (n - 1) conf'
      with NoRuleApplies -> [conf]
  in
  aux n (Cmd (c, bottom))
;;